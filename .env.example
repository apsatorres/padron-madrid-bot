# Telegram Bot Configuration
# 1. Habla con @BotFather en Telegram y crea un nuevo bot con /newbot
# 2. Copia el token que te da
TELEGRAM_BOT_TOKEN=tu_token_aqui

# 3. Para obtener tu CHAT_ID:
#    - Habla con tu bot (enviale cualquier mensaje)
#    - Visita: https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#    - Busca "chat":{"id": XXXXXXXX} - ese es tu CHAT_ID
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Intervalo de chequeo en minutos (default: 30)
CHECK_INTERVAL_MINUTES=30
